{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://book-to-skill.dev/schemas/skill-spec.schema.json",
  "title": "Book-to-Skill Spec",
  "description": "A platform-neutral skill specification distilled from a book or other structured knowledge source.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "title",
    "summary",
    "goal",
    "source_book",
    "applicable_scenarios",
    "required_inputs",
    "core_principles",
    "workflow",
    "constraints",
    "output_format",
    "evaluation_checklist"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of the skill spec payload.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string",
      "description": "Stable identifier for the skill.",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable skill title."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Short description of what the skill does."
    },
    "target_user": {
      "type": "string",
      "description": "Primary intended user of the skill."
    },
    "goal": {
      "type": "string",
      "minLength": 1,
      "description": "Primary outcome this skill is designed to achieve."
    },
    "source_book": {
      "$ref": "#/$defs/sourceBook"
    },
    "applicable_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Scenarios where the skill should be applied."
    },
    "required_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/inputField"
      },
      "description": "Inputs the user should provide for the skill to work well."
    },
    "core_principles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/principle"
      },
      "description": "Key principles distilled from the source material."
    },
    "workflow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflowStep"
      },
      "description": "Ordered steps describing how the skill should operate."
    },
    "decision_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decisionRule"
      },
      "default": [],
      "description": "Conditional rules that guide the skill's behavior."
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Hard boundaries the skill should not violate."
    },
    "anti_patterns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/antiPattern"
      },
      "default": [],
      "description": "Known bad behaviors or failure modes to avoid."
    },
    "output_format": {
      "$ref": "#/$defs/outputFormat"
    },
    "example_tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/exampleTask"
      },
      "default": [],
      "description": "Example tasks that demonstrate how to use the skill."
    },
    "evaluation_checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Checklist used to judge whether the skill output is good."
    },
    "platform_adapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/platformAdapter"
      },
      "default": [],
      "description": "Optional adapter definitions for specific target platforms."
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "sourceBook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "edition": {
          "type": "string"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "pdf",
            "epub",
            "txt",
            "manual",
            "other"
          ]
        },
        "rights_note": {
          "type": "string",
          "description": "Optional note about copyright or usage constraints."
        }
      }
    },
    "inputField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "text",
            "number",
            "boolean",
            "list",
            "object"
          ]
        },
        "example": {
          "type": [
            "string",
            "number",
            "boolean",
            "array",
            "object",
            "null"
          ]
        }
      }
    },
    "principle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "workflowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "instruction"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "when_to_apply": {
          "type": "string"
        },
        "expected_output": {
          "type": "string"
        }
      }
    },
    "decisionRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition",
        "action"
      ],
      "properties": {
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "antiPattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "outputFormat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "structure"
      ],
      "properties": {
        "format": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name of the target output format."
        },
        "structure": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Ordered structure the output should follow."
        },
        "tone": {
          "type": "string"
        },
        "style_notes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "exampleTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input",
        "expected_behavior"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "input": {
          "type": "string",
          "minLength": 1
        },
        "expected_behavior": {
          "type": "string",
          "minLength": 1
        },
        "example_output": {
          "type": "string"
        }
      }
    },
    "platformAdapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "format",
        "status"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "experimental",
            "stable",
            "deprecated"
          ]
        },
        "notes": {
          "type": "string"
        },
        "payload_schema_ref": {
          "type": "string",
          "format": "uri-reference"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "visibility": {
          "type": "string",
          "enum": [
            "private",
            "unlisted",
            "public"
          ]
        }
      }
    }
  }
}
